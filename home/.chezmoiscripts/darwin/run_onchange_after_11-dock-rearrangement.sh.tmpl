#!/bin/bash

set -eufo pipefail

{{ template "utils.sh" . }}

print_color_box_center "$COLOR_YELLOW" 40 "Dock rearrangement"

echo_color "$COLOR_BLUE" "Dock rearrangement: Cleaning up Dock and rearranging icons..."

add_to_dock() {
    local label=$1
    local bundle_id=$2
    local url=$3

    echo "➕ Adding $label ($bundle_id) to Dock..."
    defaults write com.apple.dock persistent-apps -array-add "
    <dict>
        <key>tile-data</key>
        <dict>
            <key>bundle-identifier</key>
            <string>$bundle_id</string>
            <key>file-data</key>
            <dict>
                <key>_CFURLString</key>
                <string>$url</string>
                <key>_CFURLStringType</key>
                <integer>15</integer>
            </dict>
            <key>file-label</key>
            <string>$label</string>
            <key>file-type</key>
            <integer>41</integer>
        </dict>
        <key>tile-type</key>
        <string>file-tile</string>
    </dict>"
}

# Finder 빼고 전체 제거
defaults write com.apple.dock persistent-apps -array '()'

{{- range .dock.common_top }}
add_to_dock "{{ .label }}" "{{ .bundle_id }}" "{{ .url }}"
{{- end }}

# --- 중단: 생산성 및 개인 유틸리티 ---
{{- if .is_personal }}
{{- range .dock.personal_middle }}
add_to_dock "{{ .label }}" "{{ .bundle_id }}" "{{ .url }}"
{{- end }}
{{- end }}

{{- range .dock.common_middle }}
add_to_dock "{{ .label }}" "{{ .bundle_id }}" "{{ .url }}"
{{- end }}

# --- 하단: 개발 및 코어 도구 ---
{{- range .dock.common_dev }}
add_to_dock "{{ .label }}" "{{ .bundle_id }}" "{{ .url }}"
{{- end }}

{{- if .is_personal }}
{{- range .dock.personal_dev }}
add_to_dock "{{ .label }}" "{{ .bundle_id }}" "{{ .url }}"
{{- end }}
{{- end }}

{{- range .dock.common_dev_end }}
add_to_dock "{{ .label }}" "{{ .bundle_id }}" "{{ .url }}"
{{- end }}

defaults read com.apple.dock > /dev/null
killall Dock > /dev/null 2>&1 || true

echo_color "$COLOR_GREEN" "Dock rearrangement: Done."
echo ""
