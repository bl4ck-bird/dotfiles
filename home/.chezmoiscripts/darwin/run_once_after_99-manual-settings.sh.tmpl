#!/bin/bash

set -eufo pipefail

{{ template "utils.sh" . }}

print_color_box_center "$COLOR_YELLOW" 40 "Manual Settings"

echo ""
echo "======================================================="
echo "⚠️ [Manual Action Required] 시스템 설정 수동 처리 항목"
echo "======================================================="
echo "Apple의 보안 정책(SIP/TCC) 및 내부 DB 구조로 인해 CLI 자동화가 제한된 항목입니다."
echo "아래 순서에 따라 열리는 설정 창에서 직접 세팅을 완료해 주십시오."

echo "-------------------------------------------------------"
echo "[Apple ID > iCloud > iCloud에 저장됨 > iCloud Drive]"
echo "    - 데스크탑 및 문서 폴더: 🟢 활성화"
echo "-------------------------------------------------------"
echo "👉 준비되셨으면 엔터(Enter) 키를 누르십시오. 설정 창이 열립니다."
read -r
open "x-apple.systempreferences:com.apple.systempreferences.AppleIDSettings?email/prefs/storage?root=APPLE_ACCOUNT&path=ICLOUD_SERVICE&dataclassId=com.apple.Dataclass.Ubiquity"

echo ""
echo "-------------------------------------------------------"
echo "[디스플레이]"
echo "    - 환경에 맞게 설정하세요. (해상도, 밝기, True Tone, HDR, 정렬)"
echo "-------------------------------------------------------"
echo "👉 준비되셨으면 엔터(Enter) 키를 누르십시오. 설정 창이 열립니다."
read -r
open "x-apple.systempreferences:com.apple.Displays-Settings.extension"

echo "-------------------------------------------------------"
echo "[일반 > 정보]"
echo "    - 이름: ✏️ 장비 목적에 맞게 변경하십시오."
echo "-------------------------------------------------------"
echo "👉 준비되셨으면 엔터(Enter) 키를 누르십시오. 설정 창이 열립니다."
read -r
open "x-apple.systempreferences:com.apple.SystemProfiler.AboutExtension"

echo ""
echo "-------------------------------------------------------"
echo "[일반 > 공유]"
echo "    - 로컬 호스트 이름: ✏️ 장비 목적에 맞게 변경하십시오."
{{ if .is_personal -}}
echo "    - 파일 공유: 🟢 활성화"
echo "        - 모든 사용자의 전체 디스크 접근 허용: 🟢 활성화"
echo "        - 옵션"
echo "            - SMB를 사용하여 파일 및 폴더 공유: 🟢 활성화"
echo "            - Windows 파일 공유: 🟢 개인 계정 활성화"
echo "    - 원격 로그인: 🟢 활성화"
echo "        - 원격 사용자의 전체 디스크 접근 허용: 🟢 활성화"
echo "        - 다음 사용자의 접근을 허용: 📌 다음 사용자만"
echo "            - 개인 계정 추가"
{{ end -}}
echo "-------------------------------------------------------"
echo "👉 준비되셨으면 엔터(Enter) 키를 누르십시오. 설정 창이 열립니다."
read -r
open "x-apple.systempreferences:com.apple.Sharing-Settings.extension"

echo ""
echo "-------------------------------------------------------"
echo "[일반 > 날짜 및 시간]"
echo "    - 자동으로 시간 및 날짜 설정: 🟢 활성화"
echo "    - 사용자의 현재 위치를 사용하여 자동으로 시간대 설정: 🔴 비활성화"
echo "    - 가장 가까운 도시: 서울 (대한민국 표준시)"
echo "-------------------------------------------------------"
echo "👉 준비되셨으면 엔터(Enter) 키를 누르십시오. 설정 창이 열립니다."
read -r
open "x-apple.systempreferences:com.apple.Date-Time-Settings.extension"

echo ""
echo "-------------------------------------------------------"
echo "[제어 센터]"
echo "    - 최근 문서, 응용 프로그램 및 서버: 🔴 없음"
echo "-------------------------------------------------------"
echo "👉 준비되셨으면 엔터(Enter) 키를 누르십시오. 설정 창이 열립니다."
read -r
open "x-apple.systempreferences:com.apple.ControlCenter-Settings.extension"

echo ""
echo "======================================================="
echo "🎉 모든 터미널 기반 설정이 완료되었습니다. 재부팅을 권장합니다."
echo "======================================================="

echo "✅ macOS 기본 설정이 완료되었습니다. 일부 설정은 로그아웃 후 반영됩니다."
