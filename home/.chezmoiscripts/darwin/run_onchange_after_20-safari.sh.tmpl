#!/bin/bash

set -eufo pipefail

source "{{ .chezmoi.sourceDir }}/.scripts/utils.sh"

print_color_box_center "$COLOR_YELLOW" 40 "Safari.app Settings"

echo_color "$COLOR_BLUE" "Safari.app Settings: Starting..."

## 메뉴 > 보기 > 사이드바: 🟢 보기 (탭 그룹: 0, 북마크 2, 읽기 목록: 3)
defaults write com.apple.safari ShowSidebarInNewWindows -bool true
defaults write com.apple.safari SidebarViewModeIdentifierV2 -int 0
## 메뉴 > 보기 > 즐겨찾기 막대: 🟢 보기
defaults write com.apple.safari ShowFavoritesBar-v2 -bool true
## 일반
### 홈페이지: ✏️ https://duckduckgo.com/ (TODO: 미동작 확인 필요)
defaults write com.apple.safari HomePage -string "https://duckduckgo.com/"
### 방문 기록 항목 제거: 📌 수동
defaults write com.apple.safari HistoryAgeInDaysLimit -int 365000
### 다운로드 목록 항목 제거: 📌 1일 후 (수동: 0, Safari 종료할때: 1, 다운로드가 완료되었을 때: 2, 1일 후: 3)
defaults write com.apple.safari DownloadsClearingPolicy -int 3
### 다운로드 후 '안전한' 파일 열기: 🔴
defaults write com.apple.safari AutoOpenSafeDownloads -bool false
## 자동 완성
### 나의 연락처에 있는 정보 사용하기: 🔴
defaults write com.apple.safari AutoFillFromAddressBook -bool false
### 사용자 이름 및 암호: 🔴
defaults write com.apple.safari AutoFillFromiCloudKeychain -bool false
defaults write com.apple.safari AutoFillPasswords -bool false
### 신용카드: 🔴
defaults write com.apple.safari AutoFillCreditCardData -bool false
### 기타 양식: 🔴
defaults write com.apple.safari AutoFillMiscellaneousForms -bool false
## 검색
### 검색 엔진: 📌 DuckDuckGo
defaults write com.apple.safari SearchProviderShortName -string "DuckDuckGo"
defaults write com.apple.safari WBSOfflineSearchSuggestionsModelGoogleWasDefaultSearchEngineKey -bool false
## 개인정보 보호
### 웹사이트 추적 > 크로스 사이트 추적 방지: 🟢
defaults write com.apple.safari WebKitPreferences.storageBlockingPolicy -bool true
## 고급
### 스마트 검색 필드 > 전체 웹사이트 주소 보기: 🟢
defaults write com.apple.Safari ShowFullURLInSmartSearchField -bool true
### 손쉬운 사용
#### Tab을 눌러 웹 페이지에 있는 각 항목을 하이라이트: 🟢
defaults write com.apple.Safari WebKitPreferences.tabFocusesLinks -bool true
defaults write com.apple.Safari WebKitTabToLinksPreferenceKey -bool true
### 개인정보 보호
#### 고급 추적 및 핑거프린팅 방지 사용: 🟢 (개인정보 보호 브라우징에서)
defaults write com.apple.Safari EnableEnhancedPrivacyInPrivateBrowsing -bool true
defaults write com.apple.Safari EnableEnhancedPrivacyInRegularBrowsing -bool false
#### 광고 효과에 대한 개인정보 보호 측정 허용: 🔴
defaults write com.apple.Safari privateClickMeasurementEnabled -bool true
### 웹 개발자를 위한 기능 보기: 🟢 (TODO: 미동작 확인 필요)
defaults write com.apple.Safari IncludeDevelopMenu -bool true
defaults write com.apple.Safari WebKitDeveloperExtrasEnabledPreferenceKey -bool true
defaults write com.apple.Safari WebKitPreferences.developerExtrasEnabled -bool true

# 텍스트 대치: 🔴
defaults write com.apple.Safari WebAutomaticTextReplacementEnabled -bool false
# 스마트 대시: 🔴
defaults write com.apple.Safari WebAutomaticDashSubstitutionEnabled -bool false
# 스마트 인용 부호: 🔴
defaults write com.apple.Safari WebAutomaticQuoteSubstitutionEnabled -bool false

defaults read com.apple.Safari > /dev/null
killall Safari > /dev/null 2>&1 || true

echo_color "$COLOR_GREEN" "Safari.app Settings: Done."
echo ""
