# ===================================================================
# [Config] zsh-autosuggestions 플러그인 사전 설정
# ===================================================================
# 과거 실행 히스토리나 자동 완성 데이터를 바탕으로 흐린 회색 텍스트(제안)를 띄워줍니다.
# 플러그인이 로드(95번)되기 전에 동작 전략을 정의해야 정상 반영됩니다.
#
# [적용된 최적화]
# - 전략(Strategy) : history 우선, 실패 시 completion 엔진 활용
# - 퍼포먼스 제어  : 긴 텍스트 붙여넣기 시 렉을 방지하기 위해 최대 버퍼 사이즈 20 제한

# 1. 제안 전략 설정
# history: 과거 히스토리 기반 (기본값)
# completion: 자동완성 엔진 결과 기반 (강력하지만 약간의 지연 발생 가능)
ZSH_AUTOSUGGEST_STRATEGY=(history completion)

# 2. 성능 최적화: 너무 긴 라인에서는 제안 비활성화 (대량의 데이터 붙여넣기 시 렉 방지)
ZSH_AUTOSUGGEST_BUFFER_MAX_SIZE=20

# 위젯 설정 (명령어 입력 중 제안을 수락하는 키 바인딩 커스텀 시 사용)
# 기본은 '오른쪽 방향키'이나, Ctrl+Space 등으로 확장 가능
bindkey '^ ' autosuggest-accept
