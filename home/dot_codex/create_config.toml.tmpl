# Created by chezmoi only when ~/.codex/config.toml is missing.
# After creation, Codex owns this runtime file and may update it.

model = "gpt-5.5"
model_reasoning_effort = "high"

[marketplaces.openai-bundled]
source_type = "local"
source = "{{ .chezmoi.homeDir }}/.codex/.tmp/bundled-marketplaces/openai-bundled"

[marketplaces.openai-primary-runtime]
source_type = "local"
source = "{{ .chezmoi.homeDir }}/.cache/codex-runtimes/codex-primary-runtime/plugins/openai-primary-runtime"

[marketplaces.claude-plugins-official]
source_type = "git"
source = "https://github.com/anthropics/claude-plugins-official.git"

[plugins."documents@openai-primary-runtime"]
enabled = true

[plugins."spreadsheets@openai-primary-runtime"]
enabled = true

[plugins."presentations@openai-primary-runtime"]
enabled = true

[plugins."claude-code-setup@claude-plugins-official"]
enabled = true

[plugins."claude-md-management@claude-plugins-official"]
enabled = true

[plugins."code-review@claude-plugins-official"]
enabled = true

[plugins."code-simplifier@claude-plugins-official"]
enabled = true

[plugins."commit-commands@claude-plugins-official"]
enabled = true

[plugins."feature-dev@claude-plugins-official"]
enabled = true

[plugins."hookify@claude-plugins-official"]
enabled = true

[plugins."pr-review-toolkit@claude-plugins-official"]
enabled = true

[plugins."ralph-loop@claude-plugins-official"]
enabled = false

[plugins."security-guidance@claude-plugins-official"]
enabled = true

[plugins."superpowers@claude-plugins-official"]
enabled = false

[plugins."superpowers@openai-curated"]
enabled = false

[plugins."browser-use@openai-bundled"]
enabled = true

[features]
memories = true
multi_agent = true
